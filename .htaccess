# Elite Luxury Bookings - Premium URL Engine
# Removes .html extension and handles trailing slashes for a professional, clean look

RewriteEngine On

# 1. Redirect /page.html to /page (Clean SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteRule ^(.*)\.html$ /$1 [R=301,L]

# 2. Redirect /page/ to /page (Remove Trailing Slash for Canonical URL)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# 3. Silently serve page.html when /page is requested
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
