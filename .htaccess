# Elite Luxury Bookings - Premium Folder URL Engine
# This configuration ensures a professional directory-based look for SEO.

RewriteEngine On

# Add X-Robots-Tag for SEO compliance
<IfModule mod_headers.c>
    SetEnvIf Request_URI "^/(tag|category)/" NOINDEX_URL
    Header set X-Robots-Tag "noindex, follow" env=NOINDEX_URL
    Header set X-Robots-Tag "index, follow" env=!NOINDEX_URL
</IfModule>

# Enforce HTTPS and non-WWW
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://eliteluxurybookings.com/$1 [L,R=301]

# Consolidation Redirects: Mallorca to Formentera Private Boat Trip
RewriteRule ^boat-trip-from-mallorca-to-formentera(\.html)?/?$ https://eliteluxurybookings.com/private-boat-trip-mallorca-to-formentera/ [R=301,NC,L]
RewriteRule ^mallorca-to-formentera-private-boat-cost(\.html)?/?$ https://eliteluxurybookings.com/private-boat-trip-mallorca-to-formentera/ [R=301,NC,L]
RewriteRule ^yacht-charter-mallorca-formentera(\.html)?/?$ https://eliteluxurybookings.com/private-boat-trip-mallorca-to-formentera/ [R=301,NC,L]

# 301 redirects for GSC missing/deleted pages
RewriteRule ^different-types-of-private-jets-which-one-is-right-for-you(\.html)?/?$ https://eliteluxurybookings.com/types-of-private-jets/ [R=301,NC,L]
RewriteRule ^private-jet-empty-leg-deals(\.html)?/?$ https://eliteluxurybookings.com/empty-leg-flights-guide/ [R=301,NC,L]
RewriteRule ^private-jet-charter-cost-guide-2026(\.html)?/?$ https://eliteluxurybookings.com/private-jet-charter-cost-estimator/ [R=301,NC,L]

# 0. Global Error Handling
ErrorDocument 404 https://eliteluxurybookings.com/

# 1. Enforce Trailing Slash (Global)
# If a request doesn't end in a slash, and it's not a file, redirect it.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ %{REQUEST_URI}/ [L,R=301]

# 2. Redirect /page.html to /page/ (Clean SEO Migration)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteRule ^(.*)\.html$ /$1/ [R=301,L]

# 3. Handle Root Index requests
# Ensures that index.html is served from directories automatically (Apache Default)
DirectoryIndex index.html

# 4. Internal Rewrite (Map /page or /page/ to page.html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/?$ $1.html [L]

# 5. PHP Handler Mapping (Forces the server to process PHP files)
<IfModule mod_mime.c>
    AddHandler application/x-httpd-php .php .php5 .phtml
    AddType application/x-httpd-php .php .php5 .phtml
</IfModule>

# 6. PHP Blocking Shield (Security First)
# This forces the server to NEVER serve .php files, EXCEPT for our lead handler.
<FilesMatch "\.(php|php5|php4|php3|phtml|phps)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# EXCEPTION: Allow the specific Lead Handler script to run
<Files "submit-lead.php">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Allow from all
    </IfModule>
</Files>

# 5.5. Block public access to CSV backups (Security & Privacy Protection)
<Files "leads_backup.csv">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</Files>


# 6. Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresDefault "access plus 2 days"
</IfModule>
